# NIMBUS online-stage configuration (burst detector + per-node budget).
#
# PROCESS-level environment variables, auto-loaded at startup by main via
# online.LoadEnvFile (override the path with NIMBUS_BURST_ENV_FILE). They are
# NOT part of the Nimbus CRD: the burst detector is a single cluster-wide
# component started before any Nimbus exists, so its tuning belongs to the
# process. An explicitly-exported env var wins over a value here; a missing
# file or line falls back to the same built-in default shown.
#
# Values below are the defaults (OVERVIEW §8.2 / §5.5).

# --- Burst detector (EWMA cold-start rate) ---------------------------------

# Fraction of each node's free CPU held back in BURST mode, leaving headroom
# for the rest of a cold-start wave. 0.30 = reserve 30%.
NIMBUS_BURST_RESERVE_RATIO=0.30

# Smoothed cold-start rate (events/sec) at or above which NORMAL flips to BURST.
NIMBUS_BURST_THRESHOLD_RATE=1.0

# Smoothed rate-of-change (acceleration) that flips to BURST early, before the
# absolute rate threshold is reached.
NIMBUS_BURST_THRESHOLD_DELTA=0.15

# EWMA smoothing for the rate (velocity). Higher = reacts faster but noisier.
NIMBUS_BURST_EWMA_ALPHA=0.30

# EWMA smoothing for the rate-of-change (acceleration).
NIMBUS_BURST_EWMA_BETA=0.20

# Decay-loop tick period (bleeds the rate down during quiet). Go duration.
NIMBUS_BURST_DECAY_INTERVAL=5s

# Quiet window with no cold-starts before BURST decays back to NORMAL.
NIMBUS_BURST_DECAY_QUIET=30s

# --- Per-node serverless budget (waterfall) --------------------------------

# Soft cap: NIMBUS won't admit serverless pods above this percent of a node's
# allocatable CPU. free_n = (PCT/100)*allocatable - used_n. Integer [1,100].
NIMBUS_BUDGET_PCT=70

# --- /decide HTTP endpoint -------------------------------------------------

# Address the synchronous /decide server listens on (the forked KPA POSTs here).
NIMBUS_DECIDE_ADDR=:8080
